{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "extends": [
    "./node_modules/ultracite/config/oxlint/core/.oxlintrc.json",
    "./node_modules/ultracite/config/oxlint/react/.oxlintrc.json"
  ],
  "ignorePatterns": [
    "packages/backend/convex/_generated/**",
    "packages/backend/convex/betterAuth/_generated/**",
    "packages/backend/convex/betterAuth/schema.ts",
    "apps/web/src/routeTree.gen.ts"
  ],
  "rules": {
    "jsx-a11y/label-has-associated-control": "off",
    "react-perf/jsx-no-new-function-as-prop": "off"
  },
  "overrides": [
    {
      "files": ["packages/ui/src/**"],
      "rules": {
        "func-style": "off",
        "jsx-a11y/click-events-have-key-events": "off",
        "complexity": "off",
        "jsx-a11y/prefer-tag-over-role": "off",
        "jsx-a11y/role-has-required-aria-props": "off",
        "no-nested-ternary": "off",
        "no-plusplus": "off",
        "no-shadow": "off",
        "no-use-before-define": "off",
        "no-useless-return": "off",
        "no-negated-condition": "off",
        "prefer-destructuring": "off",
        "promise/prefer-await-to-callbacks": "off",
        "react-hooks/exhaustive-deps": "off",
        "react/no-array-index-key": "off",
        "react/no-clone-element": "off",
        "unicorn/no-nested-ternary": "off",
        "@typescript-eslint/no-explicit-any": "off",
        "array-callback-return": "off"
      }
    },
    {
      "files": [
        "packages/backend/convex/healthCheck.ts",
        "packages/backend/convex/privateData.ts"
      ],
      "rules": {
        "unicorn/filename-case": "off"
      }
    }
  ]
}
